# ===== App =====
APP_ENV=development
APP_NAME=ROC Portal
APP_SECRET_KEY=change-me-to-64-char-random-string
APP_BASE_URL=https://localhost:7789
APP_DEFAULT_LOCALE=id
APP_SUPPORTED_LOCALES=id,en

# ===== Database =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=roc_portal
POSTGRES_USER=roc
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+psycopg://roc:changeme_strong_password@postgres:5432/roc_portal

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== Auth / JWT =====
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7
PASSWORD_MIN_LENGTH=12
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MIN=15

# ===== Azure / Power BI (Service Principal) =====
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
PBI_API_BASE=https://api.powerbi.com/v1.0/myorg
PBI_AUTHORITY=https://login.microsoftonline.com
PBI_SCOPE=https://analysis.windows.net/powerbi/api/.default
PBI_EMBED_TOKEN_LIFETIME_MIN=60

# ===== SMTP (forgot password) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_TLS=true

# ===== Multi-tenant =====
TENANT_RESOLUTION=subdomain  # subdomain | path
TENANT_BASE_DOMAIN=portal.example.com
DEFAULT_TENANT_SLUG=default

# ===== Security / CORS =====
ALLOWED_HOSTS=localhost,*.portal.example.com
CSRF_COOKIE_NAME=csrftoken
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=strict

# ===== Rate Limit =====
RATE_LIMIT_PER_MINUTE=60
EMBED_RATE_LIMIT_PER_MINUTE=30
EXPORT_RATE_LIMIT_PER_HOUR=5
